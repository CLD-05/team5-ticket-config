          "expr": "sum by (pool) (hikaricp_connections_pending{pool=\"booking-hikari\"})",
          "legendFormat": "pending",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 103,
      "collapsed": false,
      "title": "4. Redis(ElastiCache) & 톰캣 스레드 (2026-07-02 관측 정비)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 69
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Redis 엔진 CPU (처리 천장 / EngineCPUUtilization)",
      "id": 200,
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 70
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "aws_elasticache_engine_cpuutilization_maximum",
          "legendFormat": "{{cache_cluster_id}} engine-cpu max",
          "refId": "A"
        },
